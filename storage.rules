rules_version = '2';

// Reglas de Cloud Storage para NDTracker5S
// Pegar en: Firebase Console > Storage > pestaña "Rules" (Reglas)
//
// Criterio:
//  - LECTURA pública: cualquiera puede ver las fotos (la app las muestra con <img src=URL>).
//  - ESCRITURA solo autenticados: incluye usuarios con cuenta Y operarios anónimos
//    (signInAnonymously). Nadie sin sesión de Firebase puede subir.
//  - Límite de tamaño 2MB y solo imágenes, como protección extra.

service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de la app, bajo la carpeta nd5s/
    match /nd5s/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Todo lo demás bloqueado
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
